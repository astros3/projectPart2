<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    >
    <!--
       Top Bar
    -->
    <LinearLayout
        android:id="@+id/topbar_notification_log"
        android:layout_width="0dp"
        android:layout_height="65dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="5dp"
        >
        <!-- Back: arrow left of bar content (dark arrow on white bar) -->
        <ImageView
            android:id="@+id/back_button_notification_log"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back_arrow" />

        <!--
           Text
        -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"

            android:layout_marginStart="80dp"



            android:layout_weight="1"


            android:gravity="center_vertical"
            >

            <!--
               Text
            -->
            <TextView
                android:id="@+id/search_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFICATION LOG"
                android:textSize="25sp"


                android:layout_marginStart="35dp"


                />
        </LinearLayout>

    </LinearLayout>



    <!--
       List
    -->
    <ListView

        android:id="@+id/notification_log_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/button_background"

        android:divider="@android:color/transparent"

        android:dividerHeight="10dp"
        android:paddingTop="5dp"

        android:paddingBottom="5dp"

        android:elevation="1dp"
        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/topbar_notification_log"

        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        >

    </ListView>


</androidx.constraintlayout.widget.ConstraintLayout>