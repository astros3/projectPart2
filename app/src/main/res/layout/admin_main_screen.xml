<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    >
    <!--
       Top Bar
    -->
    <LinearLayout
        android:id="@+id/topbar"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- Back to role selection (same pattern as other admin screens) -->
        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:src="@drawable/ic_back_arrow"
            android:tint="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/admin_dashboard"
            android:textColor="@color/toolbar_content_dark"
            android:textSize="25sp"
            android:textStyle="bold" />

        <!-- Spacer so title stays centered (same visual weight as back control) -->
        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/admin_review_events_button"
        android:layout_width="0dp"
        android:layout_height="60dp"

        android:background="#F5FFFF"
        android:backgroundTint="@color/black"

        android:clickable="true"

        android:elevation="5dp"



        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="30dp"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topbar"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="REVIEW EVENTS"
            android:textColor="@color/white"

            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="›"
            android:textColor="@color/white"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/admin_review_profile_button"
        android:layout_width="0dp"
        android:layout_height="60dp"

        android:background="#F5FFFF"
        android:backgroundTint="@color/black"

        android:clickable="true"

        android:elevation="5dp"



        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="30dp"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/admin_review_events_button"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="REVIEW PROFILES"
            android:textColor="@color/white"

            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="›"
            android:textColor="@color/white"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/admin_review_image_button"
        android:layout_width="0dp"
        android:layout_height="60dp"


        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"

        android:layout_marginEnd="30dp"


        android:background="#F5FFFF"
        android:backgroundTint="@color/black"
        android:clickable="true"
        android:elevation="5dp"
        android:gravity="center_vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/admin_review_profile_button">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"

            android:layout_weight="1"

            android:text="REVIEW IMAGES"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="›"
            android:textColor="@color/white"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/admin_review_notification_log_button"
        android:layout_width="0dp"
        android:layout_height="60dp"

        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"

        android:layout_marginEnd="30dp"


        android:background="#F5FFFF"
        android:backgroundTint="@color/black"
        android:clickable="true"
        android:elevation="5dp"
        android:gravity="center_vertical"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/admin_review_image_button">

        <TextView
            android:layout_width="278dp"
            android:layout_height="wrap_content"

            android:layout_weight="1"

            android:text="REVIEW NOTIFICATION LOG"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"


            android:text="›"
            android:textColor="@color/white"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/admin_profile_button"
        android:layout_width="0dp"
        android:layout_height="60dp"


        android:background="#F5FFFF"
        android:backgroundTint="@color/black"
        android:clickable="true"

        android:elevation="5dp"



        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="30dp"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/admin_review_notification_log_button"
        >

        <TextView
            android:layout_width="278dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"

            android:layout_weight="1"

            android:text="ADMIN PROFILE"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"


            android:text="›"
            android:textColor="@color/white"
            android:textSize="25sp" />
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>