<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:padding="10dp"

    android:background="@drawable/button_background"
    android:elevation="1dp"

    android:layout_marginBottom="10dp"
    android:orientation="horizontal"

    android:gravity="center_vertical">


    >
    <!--
        The event photo
    -->
    <ImageView
        android:layout_width="21dp"
        android:id="@+id/event_photo"
        android:layout_height="21dp"
        android:layout_marginStart="20dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/bell" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"

        android:layout_marginStart="20dp"

        android:orientation="vertical">
        <!--
            notification title
        -->
        <TextView
            android:id="@+id/notification_title_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notification Title"


            android:textColor="#111111"
            android:textSize="18dp"
            android:textStyle="bold" />

        <!--
            event name and event id
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:id="@+id/notification_related_event_name_and_event_id"
            android:text="Event Name: Event ID"
            android:textSize="12dp"
            />
        <!--
            Admin/Organizer
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:id="@+id/organizerOrAdmininput"
            android:text="Organizer Name"
            android:textSize="12dp"

            />

        <!--
            time
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:id="@+id/time"
            android:text="Time"
            android:textSize="12dp"

            />

        <!--
            time
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:id="@+id/notificationmessage"
            android:text="MESSAGE HERE"
            android:textColor="#111111"
            android:textSize="18dp"

            />
    </LinearLayout>

    <!--
        Delete button
    -->
    <ImageView
        android:layout_width="50dp"
        android:id="@+id/admin_event_control_delete_button"
        android:layout_height="50dp"
        android:clickable="true"
        android:src="@drawable/delete" />



</LinearLayout>