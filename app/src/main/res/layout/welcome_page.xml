<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <LinearLayout
        android:id="@+id/logopartdisplayonly"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"


        android:gravity="center_vertical"
        android:orientation="horizontal"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/logofordisplayonly"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="@string/acc_app_logo"
            android:src="@drawable/logo" />

        <TextView
            android:id="@+id/thelogotextdisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:textStyle="bold"
            android:text="Event Lottery System"

            android:textSize="20sp"


            />

    </LinearLayout>

    <TextView
        android:id="@+id/selectyourroletextdisplayonly"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:layout_marginStart="30dp"

        android:layout_marginEnd="30dp"
        android:layout_marginTop="100dp"

        android:gravity="center_horizontal"

        android:text="Select your role to access your dashboard and manage events."
        android:textSize="18sp"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@+id/logopartdisplayonly" />

    <LinearLayout
        android:id="@+id/userbutton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"

        android:layout_marginStart="50dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/button_background"

        android:layout_marginEnd="50dp"

        android:clickable="true"
        android:focusable="true"


        android:padding="20dp"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"


        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/selectyourroletextdisplayonly">

        <ImageView
            android:id="@+id/userroleiconfordisplayonly"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/acc_entrant_sign_in"
            android:src="@drawable/person_icon" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"

            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"


                android:text="I am an User"

               />

            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Join events and view tickets"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/organizerbutton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/userbutton"
        android:background="@drawable/button_background"
        android:layout_marginStart="50dp"
        android:layout_marginTop="20dp"

        android:layout_marginEnd="50dp"

        android:clickable="true"
        android:padding="20dp"
        android:elevation="2dp"
        android:gravity="center_vertical"

        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/acc_organizer_sign_in"
            android:src="@drawable/person_icon" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"

                android:text="I am an Organizer"



                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create and manage events"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminbutton"
        android:layout_width="0dp"

        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintTop_toBottomOf="@id/organizerbutton"

        android:layout_marginStart="50dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="50dp"

        android:clickable="true"
        android:background="@drawable/button_background"
        android:padding="20dp"

        android:elevation="2dp"

        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/acc_admin_sign_in"
            android:src="@drawable/person_icon" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:text="I am an Admin"

                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Admin"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>