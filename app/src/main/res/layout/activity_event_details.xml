<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_event_details"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationContentDescription="@string/acc_navigate_up"
        app:navigationIcon="@drawable/ic_back_arrow"
        app:title="@string/event_details" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Event poster placeholder -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#E0E0E0">
                <ImageView
                    android:id="@+id/event_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/event_poster" />
            </FrameLayout>

            <TextView
                android:id="@+id/event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#0B162C"
                android:text="Lottery Event Name" />

            <TextView
                android:id="@+id/event_organizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#6C757D"
                android:text="By Organizer1" />

            <TextView
                android:id="@+id/event_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="14sp"
                android:textColor="#6C757D"
                android:text="Date" />

            <!-- Co-organizer banner: shown instead of join/leave controls when user is co-organizer -->
            <TextView
                android:id="@+id/banner_co_organizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="14dp"
                android:background="#1565C0"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:text="@string/co_organizer_banner"
                android:visibility="gone" />

            <!-- Status: NOT JOINED / PENDING -->
            <TextView
                android:id="@+id/event_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_status_bar"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="#0B162C"
                android:text="STATUS: NOT JOINED" />

            <!-- Displays the waiting list count -->
            <TextView
                android:id="@+id/event_waiting_list_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting List: 0"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>

            <!-- Request to Join / Leave the Waiting List (hidden when SELECTED; then show Accept/Decline) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_join_leave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/black"
                android:text="@string/request_to_join"
                android:textColor="@android:color/white"
                app:cornerRadius="8dp" />

            <!-- Accept / Decline invitation (visible only when status is SELECTED) -->
            <LinearLayout
                android:id="@+id/invitation_buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:id="@+id/text_invitation_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#0B162C"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_accept_invitation"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="#4CAF50"
                    android:text="@string/accept_invitation"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_decline_invitation"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E53935"
                    android:text="@string/decline_invitation"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <!-- Invite Entrants — organizer only, private events only (US 02.01.03) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_invite_entrants"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#0B162C"
                android:text="Invite Entrants"
                android:textColor="@android:color/white"
                android:visibility="gone"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_dialog_email"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/about_event"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6C757D"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                android:textColor="#0B162C"
                android:lineSpacingExtra="4dp"
                android:text="Description description description......" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/selection_criteria"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6C757D"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/event_selection_criteria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                android:textColor="#0B162C"
                android:lineSpacingExtra="4dp"
                android:text="@string/selection_criteria_placeholder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comments"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <ListView
                android:id="@+id/listComments"
                android:layout_width="match_parent"
                android:layout_height="150dp"/>

            <EditText
                android:id="@+id/editComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Write a comment"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/buttonPostComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post Comment"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
