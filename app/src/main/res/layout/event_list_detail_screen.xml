<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:background="@drawable/button_background"
    android:elevation="1dp"


    android:layout_marginBottom="10dp"

    >
    <!--
        The event photo
    -->
    <ImageView
        android:layout_width="100dp"
        android:id="@+id/event_photo"
        android:layout_height="100dp"
        android:contentDescription="@string/event_poster"
        android:src="@drawable/home_selected" />


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"

        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <!--
            Event name
        -->
        <TextView
            android:id="@+id/event_name_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name here"



            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111" />
        <!--
            Event date and time
        -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:id="@+id/event_date_input"
            android:textColor="#616161"
            android:text="Oct 24, 2024 · 10:00 AM"
            android:textSize="15sp" />
        <!-- Shown when user is SELECTED: prompt to respond to invitation -->
        <TextView
            android:id="@+id/event_invitation_prompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:text="You're selected – tap to accept or decline"
            android:textColor="#2E7D32"
            android:textSize="13sp"
            android:textStyle="bold" />
        <!--
            View Details / Respond to Invitation
        -->
        <Button
            android:layout_marginTop="10dp"
            android:id="@+id/button_view_detail"
            android:text="VIEW DETAILS"
            android:textSize="15sp"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_gravity="end"

            android:textColor="#4A7BFF"
            android:background="@android:color/transparent"

            />
    </LinearLayout>

</LinearLayout>